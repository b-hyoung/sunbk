# =============================================
# 데이터 소스 (local | supabase)
# local  → data/*.json 사용 (개발용 목 데이터)
# supabase → Supabase 사용 (운영)
# =============================================
DATA_SOURCE=local

# =============================================
# Supabase
# 대시보드 → Project Settings → API 에서 확인
# =============================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# =============================================
# NextAuth
# NEXTAUTH_SECRET 생성: openssl rand -base64 32
# =============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# =============================================
# 사이트 URL (robots.ts, sitemap.ts)
# =============================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================
# API 서버 (기본값: http://localhost:8080/api)
# =============================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# =============================================
# Resend (이메일 알림 - TODO 연동 예정)
# https://resend.com/api-keys
# =============================================
RESEND_API_KEY=
